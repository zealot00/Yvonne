{
  "mode": "dev",
  "server": {
    "bind_addr": "127.0.0.1",
    "bind_port": 8200,
    "admin": {
      "enabled": true,
      "bind_addr": "127.0.0.1",
      "bind_port": 8250
    }
  },
  "storage": {
    "type": "memory"
  },
  "unseal": {
    "type": "auto"
  },
  "logging": {
